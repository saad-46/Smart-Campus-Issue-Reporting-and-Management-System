# ============================================
# Firebase Configuration
# ============================================
# Get these values from your Firebase Console:
# 1. Go to https://console.firebase.google.com
# 2. Create a new project (or select existing)
# 3. Go to Project Settings > General
# 4. Scroll to "Your apps" > Add a Web App
# 5. Copy the config values below

# ⚠️ REPLACE THESE WITH YOUR ACTUAL VALUES ⚠️
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890abcdef

# ============================================
# IMPORTANT NOTES:
# ============================================
# - Copy this file to .env.local
# - Replace ALL values with your actual Firebase config
# - NO quotes around values
# - NO spaces before/after the = sign
# - RESTART dev server after changes: npm run dev
# ============================================

# ============================================
# AI Service (Optional - for future use)
# ============================================
# OPENAI_API_KEY=your_openai_key_here
